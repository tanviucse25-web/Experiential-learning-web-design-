<html>
<head>
<title>Workshop Registration</title>

<style>
body {
    margin: 0;
    font-family: Arial;
    background: url('https://images.unsplash.com/photo-1521737604893-d14cc237f11d') no-repeat center/cover;
}

.header {
    text-align: center;
    padding: 15px;
    background: white;
    font-size: 24px;
    font-weight: bold;
}

.navbar {
    display: flex;
    justify-content: center;
    gap: 30px;
    background: #333;
    color: white;
    padding: 10px;
}

.container {
    width: 350px;
    margin: 50px auto;
    background: rgba(255,255,255,0.95);
    padding: 20px;
    border-radius: 12px;
}

input {
    width: 100%;
    padding: 10px;
    margin: 6px 0;
}
  
.tabs input {
    display: none;
}

.tabs label {
    padding: 10px;
    background: #ddd;
    cursor: pointer;
    flex: 1;
    text-align: center;
}

.tab-buttons {
    display: flex;
}

#card:checked ~ .content #card-content,
#net:checked ~ .content #net-content {
    display: block;
}

.tab-content {
    display: none;
}

.btn {
    width: 100%;
    background: green;
    color: white;
    padding: 12px;
    border: none;
    margin-top: 15px;
    border-radius: 8px;
    text-align: center;
    display: block;
    text-decoration: none;
}

.popup {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    background: white;
    padding: 20px;
    border-radius: 12px;
    text-align: center;
    transition: 0.3s;
}

#success:target {
    transform: translate(-50%, -50%) scale(1);
}
</style>

</head>

<body>

<div class="header">Workshop Registration</div>

<div class="navbar">
    <div>Registration</div>
    <div>Payment</div>
    <div>Support</div>
</div>

<div class="container">
    <h3>Step 3: Payment Details</h3>

    <input type="text" placeholder="Full Name">
    <input type="email" placeholder="Email">

    <p><b>Choose Payment Method</b></p>

    <div class="tabs">
        <div class="tab-buttons">
            <input type="radio" id="card" name="tab" checked>
            <label for="card">Credit Card</label>

            <input type="radio" id="net" name="tab">
            <label for="net">Net Banking</label>
        </div>

        <div class="content">
            <div id="card-content" class="tab-content">
                <input type="text" placeholder="Card Number">
                <input type="text" placeholder="Expiry Date">
                <input type="text" placeholder="CVV">
            </div>

            <div id="net-content" class="tab-content">
                <input type="text" placeholder="Bank Name">
                <input type="text" placeholder="Account Number">
            </div>
        </div>
    </div>


    <a href="#success" class="btn">Confirm Registration</a>
</div>

<div id="success" class="popup">
    <h2>✅ Registration Successful!</h2>
    <p>Thank you for registering.</p>
    <a href="#" class="btn">Close</a>
</div>

</body>
</html>
